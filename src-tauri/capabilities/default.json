{
  "identifier": "default",
  "description": "Default permissions for Pixiv Desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "deep-link:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://oauth.secure.pixiv.net/**" },
        { "url": "https://app-api.pixiv.net/**" },
        { "url": "https://v2.api.pixiv.net/**" },
        { "url": "https://i.pximg.net/**" }
      ]
    },
    "dialog:default"
  ]
}
